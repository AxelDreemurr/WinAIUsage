{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinAIUsage",
  "version": "1.0.1",
  "identifier": "com.axeldreemurr.winaiusage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WinAIUsage",
        "width": 380,
        "height": 650,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Axel Silva Martínez",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
